---
interface Props {
  name: string;
  color: string;
  logo?: string;
  tagline: string;
  description: string;
  badges: string[];
  href?: string;
}

const { name, color, logo, tagline, description, badges, href } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class="bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[6px] shadow-[var(--shadow-sm)] flex flex-row overflow-hidden no-underline hover:border-blue-700 hover:shadow-[0_0_0_1px_#1C5EA6,0_8px_28px_rgba(28,94,166,0.22)] transition-all duration-150">
  <div class="w-[6px] shrink-0" style={`background:${color}`}></div>
  <div class="flex-1 p-7 pb-6">
    <div class="flex items-start justify-between gap-3 mb-4 flex-wrap">
      {logo ? (
        <div class="h-10 flex items-center shrink-0">
          <img
            src={logo}
            alt={name}
            class="partner-logo h-10 w-auto max-w-[200px] object-contain"
          />
        </div>
      ) : (
        <span
          class="inline-flex items-center justify-center text-white font-display text-[22px] font-bold rounded-[3px] px-3.5 py-[3px] shrink-0"
          style={`background:${color}`}
        >
          {name}
        </span>
      )}
      {badges.length > 0 && (
        <div class="flex gap-1.5 flex-wrap justify-end">
          {badges.map((badge) => (
            <span class="bg-blue-50 [data-theme='dark']:bg-[var(--bg-accent-subtle)] text-blue-600 [data-theme='dark']:text-blue-400 text-[10px] uppercase font-bold px-2 py-0.5 rounded-full tracking-wide font-body">
              {badge}
            </span>
          ))}
        </div>
      )}
    </div>
    <p class="text-[12px] uppercase tracking-wide text-[var(--text-muted)] font-body mb-2">{tagline}</p>
    <p class="text-[14px] text-[var(--text-secondary)] leading-[1.6] font-body max-w-[680px]">{description}</p>
  </div>
</Tag>
