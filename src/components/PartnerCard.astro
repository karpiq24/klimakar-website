---
interface Props {
  name: string;
  color: string;
  tagline: string;
  description: string;
  badges: string[];
}

const { name, color, tagline, description, badges } = Astro.props;
---

<div class="bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[6px] shadow-[var(--shadow-sm)] flex flex-row overflow-hidden">
  <div class="w-[6px] shrink-0" style={`background:${color}`}></div>
  <div class="flex-1 p-7 pb-6">
    <div class="flex items-start justify-between gap-3 mb-4 flex-wrap">
      <span
        class="inline-block text-white font-display text-[22px] font-bold rounded-[3px] px-3.5 py-[3px] shrink-0"
        style={`background:${color}`}
      >
        {name}
      </span>
      {badges.length > 0 && (
        <div class="flex gap-1.5 flex-wrap justify-end">
          {badges.map((badge) => (
            <span class="bg-blue-50 [data-theme='dark']:bg-[var(--bg-accent-subtle)] text-blue-600 [data-theme='dark']:text-blue-400 text-[10px] uppercase font-bold px-2 py-0.5 rounded-full tracking-wide font-body">
              {badge}
            </span>
          ))}
        </div>
      )}
    </div>
    <p class="text-[12px] uppercase tracking-wide text-[var(--text-muted)] font-body mb-2">{tagline}</p>
    <p class="text-[14px] text-[var(--text-secondary)] leading-[1.6] font-body max-w-[680px]">{description}</p>
  </div>
</div>
