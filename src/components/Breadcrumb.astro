---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: item.href } : {}),
  })),
};
---

<nav class="kk-breadcrumb bg-dark-50 px-10 py-2.5 border-b border-(--border-subtle)" aria-label="Breadcrumb">
  <ol class="flex items-center gap-1.5 text-[13px] font-body max-w-[1200px] mx-auto list-none p-0 m-0">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && <span class="text-(--text-muted)" aria-hidden="true">›</span>}
        {item.href && i < items.length - 1 ? (
          <a href={item.href} class="text-(--text-link) hover:underline">{item.label}</a>
        ) : (
          <span class="text-(--text-secondary)">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
