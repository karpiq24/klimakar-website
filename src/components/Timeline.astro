---
interface TimelineItem {
  year: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;
---

<ol class="timeline relative list-none m-0 p-0 pl-10 max-[600px]:pl-8">
  <!-- Vertical rail (center at x=8px) -->
  <div class="absolute left-[7px] top-3 bottom-3 w-[2px] bg-[var(--border-default)]" aria-hidden="true"></div>

  {items.map((item, i) => {
    const last = i === items.length - 1;
    return (
      <li class="relative pb-8 last:pb-0">
        <!-- Dot (16px, border-box → center at x=8px aligns with rail) -->
        <span
          class:list={[
            'absolute -left-10 top-5 w-4 h-4 rounded-full border-[3px] border-[var(--bg-page)] z-[1] max-[600px]:-left-8',
            last ? 'bg-blue-700 ring-4 ring-blue-700/15' : 'bg-blue-600',
          ]}
          aria-hidden="true"
        ></span>

        <div class="bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[8px] overflow-hidden shadow-[var(--shadow-sm)] flex flex-col min-[700px]:flex-row">
          {item.image && (
            <div class="min-[700px]:w-[400px] shrink-0 bg-[var(--bg-page)] flex items-center">
              <img
                src={item.image}
                alt={item.imageAlt ?? ''}
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6 max-[600px]:p-4 flex-1 flex flex-col justify-center">
            <span
              class:list={[
                'self-start font-display text-[13px] font-bold uppercase tracking-[0.06em] px-2.5 py-1 rounded-[4px] mb-3',
                last
                  ? 'bg-blue-700 text-white'
                  : "bg-[var(--bg-accent-subtle)] text-blue-700 [data-theme='dark']:text-blue-300",
              ]}
            >
              {item.year}
            </span>
            <h3 class="font-display text-[20px] font-bold text-[var(--text-primary)] mb-1.5 leading-snug">{item.title}</h3>
            <p class="text-[14px] text-[var(--text-secondary)] leading-[1.6] font-body">{item.description}</p>
          </div>
        </div>
      </li>
    );
  })}
</ol>
