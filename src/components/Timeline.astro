---
interface Props {
  items: { year: string; title: string; description: string }[];
}

const { items } = Astro.props;
---

<div class="timeline relative">
  <!-- Vertical line -->
  <div class="timeline-line absolute left-[64px] top-0 bottom-0 w-[2px] bg-[var(--border-subtle)]"></div>

  <div class="flex flex-col gap-8">
    {items.map((item, i) => (
      <div class="timeline-item flex gap-8 items-start">
        <!-- Year badge -->
        <div class="w-[128px] shrink-0 flex justify-end pr-6 pt-[18px] box-border">
          <span
            class:list={[
              'font-display text-[22px] font-bold',
              i === items.length - 1 ? 'text-blue-700' : 'text-[var(--text-muted)]',
            ]}
          >
            {item.year}
          </span>
        </div>
        <!-- Dot -->
        <div
          class:list={[
            'w-[14px] h-[14px] rounded-full shrink-0 mt-5 z-[1] border-[3px] border-[var(--bg-page)]',
            i === items.length - 1 ? 'bg-blue-700' : 'bg-blue-600',
          ]}
        ></div>
        <!-- Card -->
        <div class="flex-1 bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[6px] px-6 py-5 shadow-[var(--shadow-sm)]">
          <h3 class="font-display text-[20px] font-bold text-[var(--text-primary)] mb-2">{item.title}</h3>
          <p class="text-[14px] text-[var(--text-secondary)] leading-[1.6] font-body">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  @media (max-width: 899px) {
    .timeline-line {
      display: none;
    }
    .timeline-item {
      flex-direction: column;
      gap: 0.5rem;
    }
    .timeline-item > div:first-child {
      width: auto;
      justify-content: flex-start;
      padding-right: 0;
      padding-top: 0;
    }
    .timeline-item > div:nth-child(2) {
      display: none;
    }
  }
</style>
