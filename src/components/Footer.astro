---
import { Phone, Clock, Mail, MapPin, Instagram, Facebook } from 'lucide-astro';
import webastoLogo from '../assets/logos/webasto.svg';
import eberspacherLogo from '../assets/logos/eberspacher.svg';
import defaLogo from '../assets/logos/defa.svg';

const currentYear = new Date().getFullYear();
---

<footer class="font-body" style="background: #060D16; padding: 48px 40px 28px;">
  <div class="max-w-[1200px] mx-auto">
    <!-- 4-column grid -->
    <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-12 mb-10 max-[900px]:grid-cols-2 max-[900px]:gap-8 max-[560px]:grid-cols-1">

      <!-- Col 1: Logo + description + partners -->
      <div>
        <div class="logo-white mb-4" style="height: 34px;">
          <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 646.9 155.9" style="height: 34px; width: auto; display: block;">
            <g><g><path class="st0" d="M278.2,101.3l-12.9-18.4l-3.3,4.1v14.3h-12.6v-49H262v20.1l15.1-20.1h15.6l-19,22.9l20.1,26.1H278.2z"/><path class="st0" d="M297.4,101.3v-49h12.6v38h19.7v11H297.4z"/><path class="st0" d="M336.3,101.3v-49h12.6v49H336.3z"/><path class="st0" d="M400.7,101.3V69.4l-12.4,31.9h-5.6l-12.3-31.9v31.9h-12.6v-49h17.6l10.2,26.6l10.3-26.6h17.6v49H400.7z"/><path class="st0" d="M455.4,101.3l-2.4-7.1h-19.3l-2.4,7.1h-14.3l18.4-49h15.9l18.5,49H455.4z M443.3,64.8l-6.2,18.4h12.5L443.3,64.8z"/><path class="st0" d="M468.1,80.9v-9.5h17.6v9.5H468.1z"/><path class="st0" d="M521.1,101.3l-12.9-18.4l-3.3,4.1v14.3h-12.6v-49h12.6v20.1L520,52.3h15.6l-19,22.9l20.1,26.1H521.1z"/><path class="st0" d="M573.6,101.3l-2.4-7.1h-19.3l-2.4,7.1h-14.3l18.4-49h15.9l18.5,49H573.6z M561.5,64.8l-6.2,18.4h12.5L561.5,64.8z"/><path class="st0" d="M618.9,101.3l-8.2-16.5h-6.5v16.5h-12.6v-49h24.5c10.9,0,17,7.2,17,16.3c0,8.5-5.2,13.1-9.8,14.7l10,18H618.9z M620.3,68.5c0-3.3-2.8-5.2-6.1-5.2h-10v10.5h10C617.5,73.8,620.3,72,620.3,68.5z"/></g><g><path class="st0" d="M116.9,91.5H90.1c-3.8,0-6.8,3.1-6.8,6.8v0c0,3.8,3.1,6.8,6.8,6.8h26.9c3.8,0,6.8-3.1,6.8-6.8v0C123.8,94.6,120.7,91.5,116.9,91.5z"/><path class="st0" d="M122.2,108.5c0,0-2.1,1.3-4.8,1.3c-2.7,0-2.9,1.7-2.9,1.7s3.2,0.6,4.8,0.5c1.5-0.1,3.5-0.2,3.7-0.6c0.2-0.3,0.6-1,0.6-1s0.1-0.8,0.1-0.9s-0.7-0.7-0.7-0.7L122.2,108.5z"/><path class="st0" d="M120.1,50.7h-17.9c-3.8,0-6.8,3.1-6.8,6.8v0c0,3.8,3.1,6.8,6.8,6.8h17.9c3.8,0,6.8-3.1,6.8-6.8v0C127,53.8,123.9,50.7,120.1,50.7z"/><path class="st1" d="M85.1,51.9H60.7c-3.1,0-5.7,2.5-5.7,5.7v0c0,3.1,2.5,5.7,5.7,5.7h24.4c3.1,0,5.7-2.5,5.7-5.7v0C90.7,54.5,88.2,51.9,85.1,51.9z"/><path class="st1" d="M80.5,72.3H56.1c-3.1,0-5.7,2.5-5.7,5.7v0c0,3.1,2.5,5.7,5.7,5.7h24.4c3.1,0,5.7-2.5,5.7-5.7v0C86.2,74.8,83.6,72.3,80.5,72.3z"/><path class="st2" d="M41.6,73.7H28.4c-2.3,0-4.2,1.9-4.2,4.2v0c0,2.3,1.9,4.2,4.2,4.2h13.2c2.3,0,4.2-1.9,4.2-4.2v0C45.9,75.6,44,73.7,41.6,73.7z"/><path class="st1" d="M72.9,92.7H60.7c-3.1,0-5.7,2.5-5.7,5.7v0c0,3.1,2.5,5.7,5.7,5.7h12.2c3.1,0,5.7-2.5,5.7-5.7v0C78.6,95.3,76.1,92.7,72.9,92.7z"/><path class="st1" d="M95.9,33.1H80.5c-3.1,0-5.7,2.5-5.7,5.7v0c0,3.1,2.5,5.7,5.7,5.7h15.4c3.1,0,5.7-2.5,5.7-5.7v0C101.6,35.7,99,33.1,95.9,33.1z"/><path class="st1" d="M96.6,111.7H81.2c-3.1,0-5.7,2.5-5.7,5.7v0c0,3.1,2.5,5.7,5.7,5.7h15.4c3.1,0,5.7-2.5,5.7-5.7v0C102.3,114.2,99.7,111.7,96.6,111.7z"/><path class="st0" d="M122.8,46.5c0,0-1.1-0.3-2.6-0.3c-1.4,0,0-1.1,0-1.1h3.4l0.5,0.3L122.8,46.5z"/><path class="st1" d="M46.2,94.1L46.2,94.1c-2.3,0-4.2,1.9-4.2,4.2v0c0,2.3,1.9,4.2,4.2,4.2h0c2.3,0,4.2-1.9,4.2-4.2v0C50.5,96,48.6,94.1,46.2,94.1z"/><path class="st2" d="M16.5,75L16.5,75c-1.6,0-3,1.3-3,3v0c0,1.6,1.3,3,3,3h0c1.6,0,3-1.3,3-3v0C19.5,76.3,18.2,75,16.5,75z"/><path class="st1" d="M46.2,53.4L46.2,53.4c-2.3,0-4.2,1.9-4.2,4.2v0c0,2.3,1.9,4.2,4.2,4.2h0c2.3,0,4.2-1.9,4.2-4.2v0C50.4,55.3,48.5,53.4,46.2,53.4z"/><path class="st0" d="M234.5,69c-4.3-29.2-29.5-51.6-59.9-51.6c-14.7,0-28.1,5.2-38.6,13.9h-22.2c-4.2,0-7.5,3.4-7.5,7.5c0,3.7,2.7,6.8,6.2,7.4h7.7h2.8c-0.1,0.1-0.1,0.2-0.2,0.3c5,1.2,8.8,5.7,8.8,11.1c0,6.3-5.1,11.4-11.4,11.4h-5.6H99.8c-5,0-9,4-9,9c0,4.8,3.7,8.7,8.4,9H117c6.3,0,11.4,5.1,11.4,11.4c0,4.4-2.5,8.3-6.2,10.2c0.3,0.4,0.5,0.9,0.8,1.3h-9.3c-4.2,0-7.5,3.4-7.5,7.5s3.4,7.5,7.5,7.5h22.5c10.4,8.5,23.8,13.7,38.3,13.7c14.5,0,27.9-5.1,38.3-13.7c11.4-9.3,19.3-22.7,21.6-37.9c0.4-2.9,0.7-6,0.7-9C235.1,74.9,234.9,71.9,234.5,69z M174.5,117c-21.6,0-39.1-17.5-39.1-39.1s17.5-39.1,39.1-39.1s39.1,17.5,39.1,39.1S196.1,117,174.5,117z"/><path class="st1" d="M202.1,90.5l5.2-3c0.6-2.2,1.1-4.5,1.2-6.9c-0.1,0-0.2,0-0.3,0c-0.5,0-1,0.1-1.5,0.4l-10.5,6.2l-6.2-3.6V72.4l6.2-3.6l10.5,6.2c0.6,0.3,1.2,0.4,1.8,0.4c-0.2-2.4-0.6-4.7-1.2-6.9l-5.1-3l3.3-1.9c-0.8-1.8-1.8-3.5-2.9-5.1l-3.3,1.9l-0.1-6c-1.6-1.7-3.4-3.2-5.4-4.6c-0.4,0.5-0.6,1.1-0.6,1.7l0.1,12.2l-6.2,3.6l-9.6-5.6v-7.1l10.6-6c0.6-0.3,1-0.8,1.2-1.3c-2.1-1-4.3-1.8-6.6-2.4l-5.2,2.9v-3.8c-1-0.1-2-0.1-2.9-0.1c-1,0-2,0.1-2.9,0.1v3.8l-5.2-2.9c-2.3,0.6-4.5,1.4-6.6,2.4c0.2,0.5,0.7,1,1.2,1.3l10.6,6v7.1l-9.6,5.6l-6.2-3.6l0.1-12.2c0-0.7-0.2-1.3-0.6-1.8c-1.9,1.3-3.7,2.9-5.4,4.6l-0.1,6l-3.3-1.9c-1.1,1.6-2.1,3.3-2.9,5.1l3.3,1.9l-5.2,3c-0.6,2.2-1.1,4.5-1.2,6.9c0.6,0.1,1.2-0.1,1.8-0.4l10.5-6.2l6.2,3.6v11.1l-6.2,3.6l-10.5-6.2c-0.5-0.3-1-0.4-1.5-0.4c-0.1,0-0.2,0-0.3,0c0.2,2.4,0.6,4.7,1.2,6.9l5.2,3l-3.3,1.9c0.8,1.8,1.8,3.5,2.9,5.1l3.3-1.9l0.1,6c1.6,1.7,3.4,3.2,5.4,4.6c0.4-0.5,0.6-1.1,0.6-1.7l-0.1-12.2l6.2-3.6l9.6,5.6v7.1l-10.6,6c-0.6,0.3-1,0.8-1.2,1.3c2.1,1,4.3,1.8,6.6,2.4l5.2-2.9v3.8c1,0.1,2,0.1,2.9,0.1c1,0,2-0.1,2.9-0.1v-3.8l5.2,2.9c2.3-0.6,4.5-1.4,6.6-2.4c-0.2-0.5-0.7-1-1.2-1.3l-10.6-6v-7.1l9.6-5.6l6.2,3.6l-0.1,12.2c0,0.7,0.2,1.3,0.6,1.7c1.9-1.3,3.7-2.9,5.4-4.6l0.1-6l3.3,1.9c1.1-1.6,2.1-3.3,2.9-5.1L202.1,90.5z M184.2,83.5l-9.6,5.6l-9.6-5.6V72.4l9.6-5.6l9.6,5.6V83.5z"/></g></g>
          </svg>
        </div>
        <style>
          .logo-white .st0, .logo-white .st1, .logo-white .st2 { fill: #ffffff; }
        </style>
        <p class="text-[13px] text-white/65 leading-relaxed max-w-[260px] mb-4">
          Firma rodzinna z dwupokoleniową tradycją w branży chłodnictwa i ogrzewania. Wrocław, działamy od 1989 roku.
        </p>
        <div class="flex gap-4 flex-wrap items-center mb-4">
          <a href="/webasto/" class="inline-flex items-center opacity-60 hover:opacity-100 transition-opacity">
            <img src={webastoLogo.src} alt="Webasto" class="h-5 w-auto [filter:brightness(0)_invert(1)]" />
          </a>
          <a href="/eberspacher/" class="inline-flex items-center opacity-60 hover:opacity-100 transition-opacity">
            <img src={eberspacherLogo.src} alt="Eberspächer" class="h-5 w-auto [filter:brightness(0)_invert(1)]" />
          </a>
          <a href="/defa/" class="inline-flex items-center opacity-60 hover:opacity-100 transition-opacity">
            <img src={defaLogo.src} alt="DEFA" class="h-5 w-auto [filter:brightness(0)_invert(1)]" />
          </a>
        </div>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/__klimakar__/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/50 hover:text-white/85 transition-colors">
            <Instagram size={18} strokeWidth={1.5} />
          </a>
          <a href="https://www.facebook.com/KlimaKar/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/50 hover:text-white/85 transition-colors">
            <Facebook size={18} strokeWidth={1.5} />
          </a>
        </div>
      </div>

      <!-- Col 2: Usługi -->
      <div>
        <div class="text-[11px] font-bold uppercase tracking-widest text-blue-500 mb-3.5">Usługi</div>
        <a href="/klimatyzacja/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Klimatyzacja</a>
        <a href="/ogrzewanie-postojowe/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Ogrzewanie postojowe</a>
        <a href="/konserwacja/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Konserwacja</a>
        <a href="/tunap/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Dezynfekcja TUNAP</a>
        <a href="/dezynfekcja-bg/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Dezynfekcja BG</a>
        <a href="/cennik/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Cennik</a>
      </div>

      <!-- Col 3: Informacje -->
      <div>
        <div class="text-[11px] font-bold uppercase tracking-widest text-blue-500 mb-3.5">Informacje</div>
        <a href="/o-firmie/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">O firmie</a>
        <a href="/gwarancja/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Gwarancja</a>
        <a href="/galeria/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">Galeria</a>
        <a href="/rodo/" class="block text-[13px] text-white/65 mb-2 leading-snug no-underline hover:text-white/85">RODO</a>
      </div>

      <!-- Col 4: Kontakt -->
      <div>
        <div class="text-[11px] font-bold uppercase tracking-widest text-blue-500 mb-3.5">Kontakt</div>
        <div class="flex items-start gap-2 mb-2">
          <MapPin size={14} class="text-white/55 mt-0.5 shrink-0" strokeWidth={1.5} />
          <div>
            <span class="block text-[13px] text-white/65 leading-snug">ul. Grota Roweckiego 129</span>
            <span class="block text-[13px] text-white/65 leading-snug">52-214 Wrocław</span>
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <Phone size={14} class="text-white/55 shrink-0" strokeWidth={1.5} />
          <div>
            <a href="tel:713371450" class="block text-[13px] text-white/65 leading-snug no-underline hover:text-white/85">71 337 14 50</a>
            <a href="tel:605594506" class="block text-[13px] text-white/65 leading-snug no-underline hover:text-white/85">605 594 506</a>
          </div>
        </div>
        <div class="flex items-center gap-2 mb-2">
          <Mail size={14} class="text-white/55 shrink-0" strokeWidth={1.5} />
          <a href="mailto:serwis@klima-kar.pl" class="text-[13px] text-white/65 leading-snug no-underline hover:text-white/85">serwis@klima-kar.pl</a>
        </div>
        <div class="flex items-center gap-2">
          <Clock size={14} class="text-white/55 shrink-0" strokeWidth={1.5} />
          <span class="text-[13px] text-white/65 leading-snug">Pon–Pt: 9:00–17:00, Sob–Nd: nieczynne</span>
        </div>
      </div>
    </div>

    <!-- Bottom copyright bar -->
    <div class="border-t border-white/7 pt-5 flex justify-between flex-wrap gap-2">
      <span class="text-xs text-white/55">&copy; {currentYear} Klima-Kar. Wszelkie prawa zastrzeżone.</span>
      <a href="mailto:serwis@klima-kar.pl" class="text-xs text-white/55 no-underline hover:text-white/70">serwis@klima-kar.pl</a>
    </div>
  </div>
</footer>
