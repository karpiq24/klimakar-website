---
interface Props {
  title: string;
  rows: { service: string; price: string }[];
  note?: string;
}

const { title, rows, note } = Astro.props;
---

<div class="bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[6px] overflow-hidden shadow-[var(--shadow-sm)]">
  <div class="bg-blue-50 [data-theme='dark']:bg-[var(--bg-accent-subtle)] px-5 py-3.5 border-b border-[var(--border-subtle)]">
    <h3 class="font-display text-[18px] font-bold text-blue-700">{title}</h3>
  </div>
  <div>
    {rows.map((row, i) => (
      <div
        class:list={[
          'flex justify-between items-baseline px-5 py-3 gap-4',
          i % 2 === 1 && 'bg-[var(--bg-page)]',
          i < rows.length - 1 && 'border-b border-[var(--border-subtle)]',
        ]}
      >
        <span class="text-[14px] font-body text-[var(--text-primary)] leading-[1.4]">{row.service}</span>
        <span class="text-[14px] font-display font-bold text-blue-700 text-right whitespace-nowrap min-w-[100px]">{row.price}</span>
      </div>
    ))}
  </div>
  {note && (
    <div class="px-5 py-3 border-t border-[var(--border-subtle)]">
      <p class="text-[12px] text-[var(--text-muted)] italic font-body">{note}</p>
    </div>
  )}
</div>
