---
interface Props {
  title: string;
  rows: { service: string; price: string }[];
  note?: string;
}

const { title, rows, note } = Astro.props;
---

<div class="bg-(--bg-surface) border border-(--border-subtle) rounded-md overflow-hidden shadow-(--shadow-sm)">
  <div class="kk-price-header bg-blue-50 px-5 py-3.5 border-b border-(--border-subtle)">
    <h3 class="kk-price-header-title font-display text-[18px] font-bold text-blue-700">{title}</h3>
  </div>
  <div>
    {rows.map((row, i) => (
      <div
        class:list={[
          'flex justify-between items-baseline px-5 py-3 gap-4',
          i % 2 === 1 && 'bg-(--bg-page)',
          i < rows.length - 1 && 'border-b border-(--border-subtle)',
        ]}
      >
        <span class="text-[14px] font-body text-(--text-primary) leading-[1.4]">{row.service}</span>
        <span class="kk-price-value text-[14px] font-display font-bold text-blue-700 text-right whitespace-nowrap min-w-[100px]">{row.price}</span>
      </div>
    ))}
  </div>
  {note && (
    <div class="px-5 py-3 border-t border-(--border-subtle)">
      <p class="text-[12px] text-(--text-muted) italic font-body">{note}</p>
    </div>
  )}
</div>
