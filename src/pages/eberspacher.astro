---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
import { Wrench, Search, CalendarCheck } from 'lucide-astro';

const controlSystems = [
  {
    name: 'EasyStart Select',
    type: 'Włącznik z wyświetlaczem',
    features: [
      'Prosta funkcja włączania i wyłączania jednym przyciskiem',
      'Funkcja wyświetlania informacji zwrotnej',
      'Przejrzysty wyświetlacz i wygodne przyciski',
      'Odczyt nastawionej i aktualnej temperatury',
      'Zalecany do ogrzewań powietrznych',
    ],
  },
  {
    name: 'EasyStart Timer',
    type: 'Programator tygodniowy',
    features: [
      'Programowanie w cyklu tygodniowym',
      'Możliwość ustawienia trzech programów',
      'Przejrzysty wyświetlacz i wygodne przyciski',
      'Funkcja informacji zwrotnej',
      'Wybór czasu pracy ogrzewania',
    ],
  },
  {
    name: 'EasyStart Remote',
    type: 'Pilot radiowy',
    features: [
      'Zasięg do 1000 metrów',
      'Funkcja informacji zwrotnej',
      'Prosta obsługa przyciskami Wł. / Wył.',
      'Wybór grzania lub wentylacji (zima/lato)',
      'Czas działania od 10 do 60 minut',
    ],
  },
  {
    name: 'EasyStart Remote+',
    type: 'Pilot z wyświetlaczem i programowaniem',
    features: [
      'Zasięg do 1000 metrów z informacją zwrotną',
      'Programowanie czasu odjazdu (automatyczne)',
      'Trzy programy w cyklu tygodniowym',
      'Odczyt temperatury wnętrza pojazdu',
      'Wybór grzania lub wentylacji (zima/lato)',
    ],
  },
  {
    name: 'EasyStart Web',
    type: 'Sterowanie przez internet',
    features: [
      'Sterowanie z dowolnego miejsca przez internet',
      'Bezpłatna aplikacja na smartfony',
      'Sterowanie przez przeglądarkę internetową',
      'Automatyczne programowanie czasu odjazdu',
      'Informacja o statusie i temperaturze wnętrza',
    ],
  },
];
---

<BaseLayout
  title="Eberspächer — Klima-Kar"
  description="Autoryzowany Serwis Eberspächer we Wrocławiu. Montaż, naprawa i diagnostyka ogrzewań postojowych Eberspächer. Systemy sterowania EasyStart."
>
  <Breadcrumb items={[
    { label: "Strona główna", href: "/" },
    { label: "Ogrzewanie postojowe", href: "/ogrzewanie-postojowe/" },
    { label: "Eberspächer" },
  ]} />

  <PageHero
    label="Eberspächer"
    title="Autoryzowany Serwis<br>Eberspächer"
    description="Jesteśmy autoryzowanym serwisem Eberspächer. Nasze wieloletnie doświadczenie i wiedza pozwalają na wykonywanie profesjonalnych napraw i montaży nowych instalacji. Wykonujemy również naprawy gwarancyjne."
  />

  <!-- Services section -->
  <section class="bg-[var(--bg-page)] py-14 px-6 sm:px-10">
    <div class="mx-auto max-w-[1200px]">

      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-bold text-[var(--text-primary)] mb-6">Nasze usługi</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">

        <ServiceCard
          title="Montaż ogrzewaczy"
          description="Profesjonalny montaż nowych ogrzewań postojowych Eberspächer dla pojazdów osobowych i dostawczych. Dobieramy odpowiedni zestaw montażowy do każdego modelu pojazdu."
        >
          <Wrench size={22} />
        </ServiceCard>

        <ServiceCard
          title="Naprawa i serwis"
          description="Naprawy gwarancyjne i pogwarancyjne. Pełna diagnostyka komputerowa, wymiana podzespołów, naprawa instalacji. Diagnostyka usterek ogrzewań spalinowych."
        >
          <Search size={22} />
        </ServiceCard>

        <ServiceCard
          title="Przegląd serwisowy"
          description="Regularne przeglądy serwisowe ogrzewań Eberspächer. Kontrola stanu technicznego, czyszczenie, sprawdzenie poprawności działania wszystkich podzespołów."
        >
          <CalendarCheck size={22} />
        </ServiceCard>

      </div>

      <!-- Control systems section -->
      <h2 class="font-display text-[clamp(24px,3vw,32px)] font-bold text-[var(--text-primary)] mb-2">Systemy sterowania Eberspächer</h2>
      <p class="text-[14px] text-[var(--text-secondary)] font-body mb-6 max-w-[680px]">
        Wybierz sposób sterowania ogrzewaniem postojowym dopasowany do Twoich potrzeb — od prostego włącznika po sterowanie smartfonem.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        {controlSystems.map((system) => (
          <div class="bg-[var(--bg-surface)] border border-[var(--border-subtle)] rounded-[6px] p-[22px] shadow-[var(--shadow-xs)] flex flex-col gap-3">
            <div class="w-[44px] h-[44px] bg-[#E85D00]/10 rounded-[10px] flex items-center justify-center">
              <span class="font-display text-[16px] font-bold text-[#E85D00]">E</span>
            </div>
            <div>
              <h3 class="font-display text-[18px] font-bold text-[var(--text-primary)] mb-0.5 leading-[1.2]">{system.name}</h3>
              <p class="text-[11px] uppercase tracking-wide text-[var(--text-muted)] font-body font-semibold mb-3">{system.type}</p>
              <ul class="space-y-1.5">
                {system.features.map((feature) => (
                  <li class="text-[13px] text-[var(--text-secondary)] leading-relaxed font-body flex items-start gap-2">
                    <span class="text-[#E85D00] mt-[3px] shrink-0">&#8226;</span>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Banner -->
      <CTABanner
        title="Zapytaj o montaż lub naprawę Eberspächer"
        subtitle="tel. 71 337 14 50 · kom. 605 594 506"
        primaryText="Umów wizytę"
        primaryHref="/kontakt/"
        variant="card"
      />

    </div>
  </section>
</BaseLayout>
