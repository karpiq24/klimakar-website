---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const siteUrl = 'https://klima-kar.wroclaw.pl';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : `${siteUrl}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Klima-Kar" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Google Fonts: Barlow + Barlow Condensed -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"AutoRepair","name":"Klima-Kar","description":"Profesjonalny serwis klimatyzacji samochodowej oraz ogrzewań postojowych Webasto, Eberspächer i DEFA we Wrocławiu.","url":"https://klima-kar.wroclaw.pl","telephone":["+48713371450","+48605594506"],"email":"serwis@klima-kar.pl","address":{"@type":"PostalAddress","streetAddress":"ul. Grota Roweckiego 129","addressLocality":"Wrocław","postalCode":"52-232","addressCountry":"PL"},"geo":{"@type":"GeoCoordinates","latitude":"51.0678","longitude":"17.0247"},"openingHoursSpecification":{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"08:00","closes":"16:00"},"image":"https://klima-kar.wroclaw.pl/images/logo.svg","priceRange":"$$","areaServed":{"@type":"City","name":"Wrocław"},"hasOfferCatalog":{"@type":"OfferCatalog","name":"Usługi","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Klimatyzacja samochodowa"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Ogrzewanie postojowe Webasto"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Ogrzewanie postojowe Eberspächer"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Ogrzewanie postojowe DEFA"}}]}})} />

    <!-- Dark mode: prevent flash -->
    <script is:inline>
      (function(){
        const t = localStorage.getItem('kk-theme') || (window.matchMedia('(prefers-color-scheme:dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body class="bg-[var(--bg-page)] min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
